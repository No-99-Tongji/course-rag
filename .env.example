# Embedding provider: qwen or local
EMBEDDING_PROVIDER=qwen

# Qwen / DashScope embedding settings
# Create an API key in Alibaba Cloud DashScope and put it here.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# Local fallback embedding model, used when EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Optional LLM answer generation. Leave empty to return retrieval summaries only.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Web server
PORT=8000
