# Embedding provider: qwen or local
EMBEDDING_PROVIDER=qwen

# Qwen / DashScope embedding settings
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# Local fallback embedding model, used when EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Optional LLM answer generation. Leave empty to return retrieval summaries only.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# MySQL / SQLAlchemy
MYSQL_DATABASE=course_rag
APP_MYSQL_USER=course_rag
APP_MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password
DATABASE_URL=mysql+aiomysql://course_rag:change-me@mysql:3306/course_rag

# Admin bootstrap. Set password before the first startup to create the first admin.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-admin-password
ADMIN_JWT_SECRET=change-me-to-a-long-random-secret
ADMIN_JWT_EXPIRE_SECONDS=86400
COOKIE_SECURE=false

# Token session lease
TOKEN_SESSION_TTL_SECONDS=900
TOKEN_HEARTBEAT_INTERVAL_SECONDS=60

# Web server
PORT=8000
